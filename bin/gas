#!/usr/bin/env bash
set -euo pipefail

SCRIPT_SOURCE="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
  RESOLVED_SOURCE="$(readlink -f "$SCRIPT_SOURCE" 2>/dev/null || true)"
  if [[ -n "$RESOLVED_SOURCE" ]]; then
    SCRIPT_SOURCE="$RESOLVED_SOURCE"
  fi
fi

ROOT_DIR="$(cd -- "$(dirname -- "$SCRIPT_SOURCE")/.." && pwd -P)"
readonly ROOT_DIR

source "$ROOT_DIR/lib/core.sh"
source "$ROOT_DIR/lib/ui.sh"
source "$ROOT_DIR/lib/detect.sh"
source "$ROOT_DIR/lib/ecosystem.sh"
source "$ROOT_DIR/lib/pm2.sh"
source "$ROOT_DIR/lib/nginx.sh"
source "$ROOT_DIR/lib/db.sh"
source "$ROOT_DIR/lib/help.sh"
source "$ROOT_DIR/lib/build.sh"
source "$ROOT_DIR/lib/deploy.sh"
source "$ROOT_DIR/lib/commands.sh"

main "$@"
